  "howItWorks": {
    "badge": "The Process",
    "title": "Holo Learn Works",
    "sub": "A seamless bridge between physical classroom technology and digital learning.",
    "steps": [
      {
        "num": "01",
        "title": "Teacher Activates Hologram",
        "desc": "The instructor uses the Hologram Fan device — one per classroom — to project 3D educational content visible to all students."
      },
      {
        "num": "02",
        "title": "Students Follow on Web",
        "desc": "Students open the web app on any device and see the synchronized lesson content in real time."
      },
      {
        "num": "03",
        "title": "AR Brings It to Life",
        "desc": "Using their device camera, students activate AR mode to overlay holographic models directly into their physical space."
      }
    ]
  },
  "features": {
    "badge": "Platform Features",
    "title": "Built for the Classroom of Tomorrow",
    "items": [
      {
        "title": "Hologram Fan Integration",
        "desc": "Seamless sync between the teacher's hologram device and the student web interface."
      },
      {
        "title": "Web-based AR",
        "desc": "No app install needed — AR runs directly in the browser using WebXR."
      },
      {
        "title": "Bilingual Interface",
        "desc": "Full Arabic and English support with RTL layout for Arabic users."
      },
      {
        "title": "Real-time Sync",
        "desc": "Lesson content updates instantly across all student devices as the teacher navigates."
      },
      {
        "title": "Interactive 3D Models",
        "desc": "Students can rotate, zoom, and inspect 3D educational models in AR."
      },
      {
        "title": "Research-grade Analytics",
        "desc": "Engagement and interaction data collected for the academic research study."
      }
    ]
  },
